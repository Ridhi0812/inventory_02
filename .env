# FILE: backend/.env
# Place this in the root of your Flask project folder
# ═══════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL= postgresql://root:7b9rOh8RbO3GhqLcbS5mty4U0fifzhNX@dpg-d8m2509kh4rs739891b0-a/inventory_mgmt_1o9a

# ── Flask ─────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false          # set to true only in local dev

# ── CORS: comma-separated list of allowed origins ─────────
# Dev:        *
# Production: https://your-frontend.vercel.app
CORS_ORIGINS=*

# ── Secret key (used by Flask sessions / extensions) ──────
SECRET_KEY=change-this-to-a-long-random-string-in-production



# ═══════════════════════════════════════════════════════
# FILE: frontend/.env
# Place this in the root of your React (CRA) project
# ═══════════════════════════════════════════════════════

# URL of your deployed backend API
# Dev local:   http://localhost:8000
# Production:  https://your-backend.onrender.com
REACT_APP_API_URL= https://inventory-02-1.onrender.com/


